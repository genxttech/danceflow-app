{
  "expo": {
    "name": "DanceFlow",
    "slug": "danceflow-student",
    "scheme": "danceflow",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.idanceflow.student",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "DanceFlow uses your location to find nearby studios and events."
      }
    },
    "android": {
      "package": "com.idanceflow.student",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#071427",
        "foregroundImage": "./assets/danceflow-logo.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    },
    "icon": "./assets/danceflow-logo.png",
    "splash": {
      "image": "./assets/danceflow-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#071427"
    }
  }
}
