    "doctor": "npx expo-doctor",
    "eas:dev:android": "npx eas build --profile development --platform android",
    "eas:dev:ios": "npx eas build --profile development --platform ios",
    "eas:preview:android": "npx eas build --profile preview --platform android",
    "eas:preview:ios": "npx eas build --profile preview --platform ios",
    "eas:prod:android": "npx eas build --profile production --platform android",
    "eas:prod:ios": "npx eas build --profile production --platform ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.101.1",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-image-picker": "~17.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.14",
    "expo-secure-store": "~15.0.7",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "react": "19.1.0",
