{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/notifications/generate",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/notifications/send",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/platform/daily-digest",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/google-calendar-sync",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/aria-digest",
      "schedule": "*/15 * * * *"
    }
  ]
}
